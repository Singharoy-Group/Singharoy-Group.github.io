---
import SiteLayout from "../layouts/SiteLayout.astro";
import { withBase as withSiteBase } from "../lib/site";

const base = import.meta.env.BASE_URL;
const withBase = (path = "") => withSiteBase(base, path);

const contactMethods = [
  {
    label: "Principal Investigator",
    value: "Abhishek Singharoy",
    detail: "asinghar@asu.edu",
    href: "mailto:asinghar@asu.edu",
  },
  {
    label: "General website inquiries",
    value: "Lab communications",
    detail: "Use email for collaboration, recruiting, or website questions.",
    href: "mailto:asinghar@asu.edu?subject=Lab%20Website%20Inquiry",
  },
];

const quickLinks = [
  { label: "People", href: withBase("/people") },
  { label: "Research", href: withBase("/research") },
  { label: "Projects", href: withBase("/projects") },
  { label: "News", href: withBase("/news") },
];
---

<style>
  .wrap {
    max-width: 1240px;
    margin: 0 auto;
    padding: 2.2rem 1.25rem 3.2rem;
  }
  .hero {
    border-radius: 28px;
    padding: 2.6rem 2.2rem;
    background:
      radial-gradient(1200px 520px at 12% 10%, rgba(99,102,241,.26), transparent 60%),
      radial-gradient(900px 520px at 90% 0%, rgba(56,189,248,.22), transparent 55%),
      radial-gradient(900px 520px at 50% 120%, rgba(16,185,129,.10), transparent 60%),
      linear-gradient(180deg, rgba(255,255,255,.94), rgba(255,255,255,.78));
    border: 1px solid rgba(0,0,0,.06);
    box-shadow: 0 18px 46px rgba(0,0,0,.08);
  }
  .kicker {
    font-size: .92rem;
    letter-spacing: .16em;
    text-transform: uppercase;
    color: rgba(0,0,0,.55);
    margin: 0 0 .55rem;
  }
  h1 {
    font-size: 3.05rem;
    line-height: 1.04;
    margin: 0 0 .85rem;
    letter-spacing: -0.02em;
    /* max-width: 25ch;  <- Removed this line */
  }
  .lead {
    font-size: 1.18rem;
    line-height: 1.65;
    color: rgba(0,0,0,.74);
    /* max-width: 82ch; <- Removed this line */
    margin: 0;
  }
  .chips {
    display: flex;
    flex-wrap: wrap;
    gap: .6rem;
    margin-top: 1.2rem;
  }
  .chip {
    font-size: 1rem;
    padding: .5rem .8rem;
    border-radius: 999px;
    border: 1px solid rgba(0,0,0,.10);
    background: rgba(255,255,255,.76);
    color: rgba(0,0,0,.72);
  }

  /* Fixed CTA spacing */
  .ctaRow {
    display: flex;
    flex-wrap: wrap;
    gap: .75rem;
    margin-top: 1.35rem;
  }
  .btn {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    gap: .5rem;
    padding: .72rem 1.05rem;
    border-radius: 999px;
    border: 1px solid rgba(0,0,0,.10);
    background: rgba(255,255,255,.90);
    color: rgba(0,0,0,.86);
    text-decoration: none;
    font-size: 1.02rem;
    font-weight: 700;
    transition: transform .15s ease, background .15s ease, border-color .15s ease;
  }
  .btn:hover {
    transform: translateY(-1px);
    background: rgba(0,0,0,.04);
    border-color: rgba(0,0,0,.14);
  }
  .btn.primary {
    background: rgba(0,0,0,.92);
    color: rgba(255,255,255,.95);
    border-color: rgba(0,0,0,.92);
  }

  .grid {
    display: grid;
    grid-template-columns: 1.2fr .8fr;
    gap: 1.25rem;
    margin-top: 1.35rem;
  }
  .stack {
    display: grid;
    gap: 1rem;
  }
  .card {
    border-radius: 22px;
    background: rgba(255,255,255,.94);
    border: 1px solid rgba(0,0,0,.06);
    box-shadow: 0 12px 28px rgba(0,0,0,.07);
    padding: 1.25rem;
  }
  .card h2 {
    margin: 0 0 .6rem;
    font-size: 1.3rem;
    letter-spacing: -0.01em;
  }
  .card p {
    margin: 0;
    font-size: 1.04rem;
    line-height: 1.66;
    color: rgba(0,0,0,.74);
  }
  .contactList {
    display: grid;
    gap: .9rem;
  }
  .contactItem {
    padding: 1rem;
    border-radius: 18px;
    background: rgba(0,0,0,.03);
    border: 1px solid rgba(0,0,0,.05);
  }
  .contactItem a {
    color: inherit;
    text-decoration: none;
  }
  .contactItem a:hover .contactValue {
    text-decoration: underline;
  }
  .contactLabel {
    margin: 0 0 .3rem;
    font-size: .9rem;
    text-transform: uppercase;
    letter-spacing: .12em;
    color: rgba(0,0,0,.52);
  }
  .contactValue {
    margin: 0;
    font-size: 1.1rem;
    font-weight: 700;
    color: rgba(0,0,0,.9);
  }
  .linkGrid {
    display: grid;
    gap: .8rem;
    margin-top: .95rem;
  }
  .quickLink {
    display: flex;
    justify-content: space-between;
    align-items: center;
    text-decoration: none;
    color: rgba(0,0,0,.84);
    padding: .9rem 1rem;
    border-radius: 16px;
    background: rgba(255,255,255,.86);
    border: 1px solid rgba(0,0,0,.08);
  }
  .quickLink:hover {
    background: rgba(0,0,0,.03);
  }

  @media (max-width: 980px) {
    .grid { grid-template-columns: 1fr; }
  }
  @media (max-width: 640px) {
    .wrap { padding: 1.6rem 1rem 2.8rem; }
    .hero { padding: 2.1rem 1.4rem; }
    h1 { font-size: 2.35rem; }
  }
</style>

<SiteLayout title="Systems Structural Biology Group">
  <main class="wrap">
    <section class="hero">
      <p class="kicker">Systems Structural Biology Group</p>
      <h1>Structural Biology, Molecular Simulation, Drug Discovery & AI.</h1>
      <p class="lead">
        We build trustworthy computational methods to connect protein structure, molecular dynamics, and human decision-making. 
        Our tools span across biophysics, applied deep learning, and adaptive human-computer interaction.
      </p>

      <div class="chips">
        <span class="chip">Structural biology</span>
        <span class="chip">Complex systems</span>
        <span class="chip">Human-centered AI</span>
        <span class="chip">Nonlinear dynamics</span>
        <span class="chip">Drug Discovery</span>
      </div>

      <div class="ctaRow">
        <a class="btn primary" href={withBase("/research")}>Explore Research</a>
        <a class="btn" href={withBase("/people")}>Meet the Team</a>
        <a class="btn" href={withBase("/join")}>Join the Lab</a>
      </div>
    </section>

    <section class="grid" aria-label="Home content">
      <div class="card">
        <h2>What we do</h2>
        <p>
          We unify simulation, learning, and human-centered design to study complex biological systems.
          Our work spans molecular modeling, data-driven inference, and adaptive decision support.
        </p>
        <ul style="margin-top: 1rem; color: rgba(0,0,0,0.74); line-height: 1.65; padding-left: 1.2rem;">
          <li><strong>Structural modeling:</strong> simulation and multiscale analysis.</li>
          <li><strong>AI + data science:</strong> statistical learning and reliable inference.</li>
          <li><strong>Complex systems:</strong> dynamical methods for molecular behavior.</li>
          <li><strong>Human-centered AI:</strong> trustworthy tools for health and discovery.</li>
        </ul>
      </div>

      <div class="stack">
        <article class="card">
          <h2>Quick links</h2>
          <div class="linkGrid">
            {quickLinks.map((item) => (
              <a class="quickLink" href={item.href}>
                <span>{item.label}</span>
                <span style="opacity: .5;">Open →</span>
              </a>
            ))}
          </div>
        </article>

        <article class="card">
          <h2>Contact</h2>
          <div class="contactList">
            {contactMethods.map((item) => (
              <div class="contactItem">
                <p class="contactLabel">{item.label}</p>
                <a href={item.href}>
                  <p class="contactValue">{item.value}</p>
                </a>
              </div>
            ))}
          </div>
        </article>
      </div>
    </section>
  </main>
</SiteLayout>```
