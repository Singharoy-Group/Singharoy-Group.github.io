---
import { getCollection } from "astro:content";
import SiteLayout from "../../layouts/SiteLayout.astro";
import { withBase as withSiteBase } from "../../lib/site";

const base = import.meta.env.BASE_URL;
const withBase = (path = "") => withSiteBase(base, path);

// 1. Fetch data
const projectEntries = await getCollection("projects");

// 2. Define Topic List
const topicDefinitions = [
  { slug: "structural-biology", label: "Structural Biology", matchTags: ["Structural Biology", "Biophysics", "Structure Prediction", "Electrostatics"] },
  { slug: "complex-systems", label: "Complex Systems", matchTags: ["Complex Systems", "Molecular Dynamics", "Brownian Dynamics", "Thermodynamic Ensembles", "MELD"] },
  { slug: "multiscale-modeling", label: "Multiscale Modeling", matchTags: ["Multiscale Modeling", "Molecular Dynamics", "Brownian Dynamics", "MELD", "Thermodynamic Ensembles"] },
  { slug: "applied-deep-learning", label: "Applied Deep Learning", matchTags: ["Applied Deep Learning", "Deep Learning", "SE3 Convolutional Networks"] },
  { slug: "human-computer-interaction", label: "Human Computer Interaction", matchTags: ["Human Computer Interaction", "STEM Education"] },
];

// 3. Helper Functions
const tagMatchesTopic = (tag = "", topic) => {
  const normalizedTag = tag.toLowerCase();
  return topic.matchTags.some((matchTag) => normalizedTag.includes(matchTag.toLowerCase()));
};

const topicsForProject = (project) =>
  topicDefinitions.filter((topic) =>
    project.data.tags?.some((tag) => tagMatchesTopic(tag, topic))
  );

const projectTopicMap = Object.fromEntries(
  projectEntries.map((project) => [project.id, topicsForProject(project).map((topic) => topic.slug)])
);

const topicSummaries = topicDefinitions.map((topic) => {
  const projects = projectEntries.filter((project) => projectTopicMap[project.id]?.includes(topic.slug));
  const people = new Map();
  for (const project of projects) {
    for (const member of project.data.team ?? []) {
      people.set(member.name, member);
    }
  }
  return { ...topic, projects, people: Array.from(people.values()).sort((a, b) => a.name.localeCompare(b.name)) };
});

const stats = [
  { label: "Active Projects", value: String(projectEntries.length) },
  { label: "Research Areas", value: String(topicDefinitions.length) },
  { label: "Team Members", value: "10+" },
  { label: "Partner Sites", value: "Multi-site" },
];
---

<style>
  :global(html) { font-family: Arial, Helvetica, sans-serif; scroll-behavior: smooth; }
  :global(body) { background: #f6f7fb; margin: 0; color: rgba(0,0,0,.9); }

  .wrap {
    max-width: 1440px;
    margin: 0 auto;
    padding: 2.25rem 1.25rem 3rem 1.25rem;
    display: grid;
    grid-template-columns: 230px minmax(0, 1fr);
    gap: 2rem;
    align-items: start;
  }

  .contentNav {
    position: sticky;
    top: 2rem;
    border-radius: 18px;
    border: 1px solid rgba(0,0,0,.07);
    background: rgba(255,255,255,.86);
    box-shadow: 0 10px 24px rgba(0,0,0,.06);
    padding: 1rem;
    max-height: calc(100vh - 4rem);
    overflow: auto;
  }

  .contentNavTitle { margin: 0 0 .75rem 0; font-size: .92rem; letter-spacing: .12em; text-transform: uppercase; color: rgba(0,0,0,.55); font-weight: 800; }
  .contentNavList { display: grid; gap: .25rem; margin: 0; padding: 0; list-style: none; }
  .contentNavLink { display: block; border-radius: 10px; padding: .48rem .55rem; color: rgba(0,0,0,.72); text-decoration: none; font-size: .94rem; }
  .contentNavLink:hover { background: rgba(0,0,0,.05); color: rgba(0,0,0,.92); }
  .contentNavSub { margin-top: .5rem; padding-top: .5rem; border-top: 1px solid rgba(0,0,0,.08); }

  .hero {
    border-radius: 26px; padding: 2.6rem 2rem;
    background: radial-gradient(1200px 420px at 12% 10%, rgba(99,102,241,.24), transparent 60%),
                radial-gradient(900px 420px at 90% 0%, rgba(56,189,248,.20), transparent 55%),
                linear-gradient(180deg, rgba(255,255,255,.92), rgba(255,255,255,.74));
    border: 1px solid rgba(0,0,0,.06); box-shadow: 0 16px 40px rgba(0,0,0,.08);
    margin-bottom: 2rem;
  }
  .heroGrid { display: grid; gap: 1.5rem; grid-template-columns: 1.3fr .9fr; align-items: center; }
  h1 { font-size: 3rem; line-height: 1.04; margin: 0; letter-spacing: -0.02em; }
  .sub { font-size: 1.16rem; line-height: 1.6; color: rgba(0,0,0,.72); margin-top: 0.5rem; }

  .btn {
    display: inline-flex; align-items: center; justify-content: center;
    padding: .82rem 1.1rem; border-radius: 18px; text-decoration: none;
    font-weight: 700; background: #111827; color: white; transition: transform .15s ease;
  }
  .btnSecondary { background: white; color: #111827; border: 1px solid rgba(0,0,0,.1); }
  .btn:hover { transform: translateY(-1px); }

  .statsGrid { display: grid; grid-template-columns: repeat(2, 1fr); gap: .9rem; }
  .statCard { border-radius: 22px; background: rgba(255,255,255,.94); border: 1px solid rgba(0,0,0,.06); padding: 1rem; box-shadow: 0 10px 24px rgba(0,0,0,.06); }
  .statValue { font-size: 2rem; font-weight: 800; margin: 0; }

  .topicMap { border-radius: 24px; background: rgba(255,255,255,.94); border: 1px solid rgba(0,0,0,.06); padding: 1.3rem; margin-bottom: 2rem; }
  .topicPills { display: flex; flex-wrap: wrap; gap: .55rem; margin-top: 1rem; }
  .topicPill { border-radius: 999px; padding: .48rem .78rem; font-size: .92rem; text-decoration: none; border: 1px solid rgba(0,0,0,.10); background: white; color: rgba(0,0,0,.74); cursor: pointer; }
  .topicPill.active { background: #111827; color: white; border-color: #111827; }

  .topicResult { display: none; margin-top: 1.5rem; padding: 1rem; background: rgba(0,0,0,.02); border-radius: 20px; border: 1px solid rgba(0,0,0,.05); }
  .topicResult.active { display: block; }
  .topicResultGrid { display: grid; grid-template-columns: 1fr 1fr; gap: 1rem; }

  .resultLink {
    display: block; margin-top: 8px; padding: 10px 14px; background: white;
    border: 1px solid rgba(0,0,0,0.08); border-radius: 12px;
    text-decoration: none; color: #111827; font-size: 0.95rem; font-weight: 600;
    transition: all 0.2s ease;
  }
  .resultLink:hover { background: #f9fafb; transform: translateY(-1px); border-color: rgba(0,0,0,0.15); }
  .resultLink small { display: block; font-weight: 400; color: #666; font-size: 0.85rem; margin-top: 2px; }

  .projectsGrid { display: grid; gap: 1.5rem; }
  .projectCard { border-radius: 24px; background: white; border: 1px solid rgba(0,0,0,.06); padding: 1.5rem; box-shadow: 0 12px 28px rgba(0,0,0,.07); }
  .projectCard.isHidden { display: none; }
  .projectGrid { display: grid; grid-template-columns: 1.2fr .8fr; gap: 1.5rem; }

  .badge { border-radius: 999px; padding: .4rem .8rem; font-size: .85rem; font-weight: 700; background: #f3f4f6; border: 1px solid rgba(0,0,0,.08); }
  .badgeActive { background: #ecfdf5; color: #047857; border-color: #bbf7d0; }
  
  .mediaContainer { margin-top: 1.2rem; border-radius: 18px; overflow: hidden; background: #000; border: 1px solid rgba(0,0,0,0.05); }
  .mediaContainer video, .mediaContainer img { width: 100%; height: auto; display: block; object-fit: cover; }

  .tagRow { display: flex; flex-wrap: wrap; gap: 0.5rem; margin-top: 1.5rem; }
  .tag { font-size: 0.82rem; font-weight: 600; background: #f3f4f6; color: #4b5563; padding: 0.35rem 0.8rem; border-radius: 10px; border: 1px solid rgba(0,0,0,0.04); }

  .sideStack { display: grid; gap: 1rem; }
  .sideCard { border-radius: 20px; border: 1px solid rgba(0,0,0,.06); background: rgba(0,0,0,.02); padding: 1rem; }
  .sideLabel { margin: 0 0 10px; font-size: .88rem; text-transform: uppercase; letter-spacing: .08em; color: rgba(0,0,0,.5); font-weight: 700; }
  
  .memberLink { display: block; padding: .85rem 1rem; text-decoration: none; color: #111827; border-radius: 16px; background: white; border: 1px solid rgba(0,0,0,.07); transition: transform 0.15s ease; }
  .memberLink:hover { transform: translateY(-1px); background: rgba(0,0,0,.01); }

  @media (max-width: 1000px) {
    .wrap { grid-template-columns: 1fr; }
    .contentNav { position: static; max-height: none; }
    .heroGrid, .projectGrid, .topicResultGrid { grid-template-columns: 1fr; }
  }
</style>

<SiteLayout title="Projects | Systems Structural Biology Group">
  <main class="wrap">
    <aside class="contentNav" aria-label="Projects contents">
      <p class="contentNavTitle">Contents</p>
      <ol class="contentNavList">
        <li><a class="contentNavLink" href="#topic-map">Topic map</a></li>
        <li><a class="contentNavLink" href="#projects">Projects</a></li>
      </ol>
      <ol class="contentNavList contentNavSub">
        {projectEntries.map((project) => (
          <li><a class="contentNavLink" href={`#${project.id}`}>{project.data.title}</a></li>
        ))}
      </ol>
    </aside>

    <div class="contentColumn">
      <section class="hero">
        <div class="heroGrid">
          <div>
            <p style="text-transform: uppercase; letter-spacing: .16em; font-size: .92rem; color: rgba(0,0,0,.55); margin: 0 0 0.5rem;">Systems Structural Biology Group</p>
            <h1>Active Projects</h1>
            <p class="sub">Exploring the intersection of structural biology, molecular dynamics, and human-centered AI.</p>
            <div style="margin-top: 1.5rem; display: flex; gap: 10px;">
              <a href="#projects" class="btn">Browse projects</a>
              <a href={withBase("people")} class="btn btnSecondary">View people</a>
            </div>
          </div>
          <div class="statsGrid">
            {stats.map((stat) => (
              <div class="statCard">
                <p style="margin:0; font-size:.9rem; color:#666;">{stat.label}</p>
                <p class="statValue">{stat.value}</p>
              </div>
            ))}
          </div>
        </div>
      </section>

      <section id="topic-map" class="topicMap">
        <h2 style="margin:0;">Key Research Areas</h2>
        <p style="color: #666; margin: 0.5rem 0 1.5rem;">Choose a topic to filter associated projects and team members.</p>
        
        <div class="topicPills">
          {topicSummaries.map((topic) => (
            <a class="topicPill" data-topic-link={topic.slug} data-topic-label={topic.label}>{topic.label}</a>
          ))}
        </div>

        {topicSummaries.map((topic) => (
          <div class="topicResult" data-topic-result={topic.slug}>
            <div class="topicResultGrid">
              <div>
                <p class="sideLabel">Projects</p>
                {topic.projects.length > 0 ? topic.projects.map(p => (
                  <a href={`#${p.id}`} class="resultLink">{p.data.title}<small>{p.data.phase}</small></a>
                )) : <p style="font-style: italic; color: #999;">No projects found.</p>}
              </div>
              <div>
                <p class="sideLabel">People</p>
                {topic.people.map(person => (
                  <a href={withBase(person.href)} class="resultLink">{person.name}<small>{person.role}</small></a>
                ))}
              </div>
            </div>
          </div>
        ))}
      </section>

      <div class="projectsGrid" id="projects">
        {projectEntries.map((project) => (
          <article class="projectCard" id={project.id} data-project-topics={projectTopicMap[project.id].join(" ")}>
            <div class="projectGrid">
              <div>
                <div style="margin-bottom: 12px; display: flex; gap: 8px;">
                  <span class={`badge ${project.data.status === 'Active' ? 'badgeActive' : ''}`}>{project.data.status}</span>
                  <span class="badge">{project.data.phase}</span>
                </div>
                <h2 style="margin:0; font-size: 1.85rem;">{project.data.title}</h2>
                <p style="line-height: 1.7; color: #444; margin-top: 1rem;">{project.data.summary}</p>
                
                {(project.data.video || project.data.thumbnail) && (
                  <div class="mediaContainer">
                    {project.data.video ? (
                      <video src={withBase(project.data.video)} controls muted loop playsinline poster={project.data.thumbnail ? withBase(project.data.thumbnail) : undefined} />
                    ) : (
                      <img src={withBase(project.data.thumbnail)} alt={project.data.title} />
                    )}
                  </div>
                )}

                <div class="tagRow">
                  {project.data.tags?.map((tag) => (
                    <span class="tag">{tag}</span>
                  ))}
                </div>
              </div>

              <div class="sideStack">
                <div class="sideCard">
                  <p class="sideLabel">Team Members</p>
                  <div style="display:grid; gap:.65rem;">
                    {project.data.team.map((member) => (
                      <a href={withBase(member.href)} class="memberLink">
                        <p style="margin:0; font-weight:700;">{member.name}</p>
                        <p style="margin:0; font-size: .9rem; color: #666;">{member.role}</p>
                      </a>
                    ))}
                  </div>
                </div>

                {project.data.updates && project.data.updates.length > 0 && (
                  <div class="sideCard">
                    <p class="sideLabel">Recent Progress</p>
                    <ul style="padding-left:1.2rem; margin:0; font-size: .95rem; line-height: 1.6; color: #555;">
                      {project.data.updates.map(u => <li>{u}</li>)}
                    </ul>
                  </div>
                )}
              </div>
            </div>
          </article>
        ))}
      </div>
    </div>
  </main>

  <script>
    const topicLinks = Array.from(document.querySelectorAll("[data-topic-link]"));
    const topicResults = Array.from(document.querySelectorAll("[data-topic-result]"));
    const projectCards = Array.from(document.querySelectorAll("[data-project-topics]"));

    const showTopic = (topicSlug) => {
      topicLinks.forEach(l => l.classList.toggle("active", l.dataset.topicLink === topicSlug));
      topicResults.forEach(r => r.classList.toggle("active", r.dataset.topicResult === topicSlug));
      projectCards.forEach(c => {
        const topics = c.dataset.projectTopics?.split(" ") || [];
        c.classList.toggle("isHidden", !!topicSlug && !topics.includes(topicSlug));
      });
    };

    topicLinks.forEach(link => {
      link.addEventListener("click", (e) => {
        e.preventDefault();
        const slug = link.dataset.topicLink || "";
        const currentActive = link.classList.contains("active");
        
        // Toggle off if clicking the same slug
        const targetSlug = currentActive ? "" : slug;
        showTopic(targetSlug);
        
        const newUrl = targetSlug ? `?topic=${targetSlug}#topic-map` : window.location.pathname + '#topic-map';
        window.history.pushState({}, "", newUrl);
      });
    });

    const urlParams = new URLSearchParams(window.location.search);
    if (urlParams.has("topic")) showTopic(urlParams.get("topic") || "");
  </script>
</SiteLayout>
